# ── Convex ──────────────────────────────────────────
# Populated by `pnpm dlx convex dev` (or `npx convex dev`) on first run
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Convex Auth (Google login) ──────────────────────
# Generate with: npx @convex-dev/auth
JWT_PRIVATE_KEY=
JWKS=

SITE_URL=http://localhost:3000

# Google OAuth client #1 — for user login (openid email profile only)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Google OAuth client #2 — for platform connections ──
# Separate client with scopes: analytics.readonly, webmasters.readonly,
# adwords, youtube.readonly, yt-analytics.readonly, business.manage
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# ── Encryption key for platform OAuth tokens at rest ──
# Generate: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=

# ── HMAC secret for signed OAuth state tokens ──
# Generate: openssl rand -hex 48
OAUTH_STATE_SECRET=

# ── Google Ads API ──
GOOGLE_ADS_DEVELOPER_TOKEN=

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs per tier — create products in Stripe dashboard first
STRIPE_PRICE_SOLO=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_AGENCY=
STRIPE_PRICE_SCALE=

# ── Anthropic (for marketing_insights tool) ──
ANTHROPIC_API_KEY=

# ── Email (Resend) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@askarlo.app

# ── Analytics ──
NEXT_PUBLIC_GTM_ID=
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
